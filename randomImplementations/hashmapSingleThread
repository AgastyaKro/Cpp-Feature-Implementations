#include <vector>
#include <cstddef>
#include <cstdint>
#include <cmath>

using namespace std;

template <typename T>
struct Node{
    Node* next_;
    T val_;
    int64_t key_;
};

template <typename T>
class hashmapSingleThread{
private:
    int64_t capacity_;
    vector<Node<T>*> buckets_;

    void resize(){
        int64_t newCapacity = capacity_ << 1;
        vector<Node<T>*> newBuckets(newCapacity, nullptr);

        for (auto& bucket : buckets_){
            Node<T>* currNode = bucket;

            while (currNode){
                Node<T>* nextNode = currNode->next_;
                insert(currNode, newBuckets);
                currNode = nextNode;
            }
        }
        buckets_ = newBuckets;
        capacity_ = newCapacity;
    }

    void insert(Node<T>* ptr, vector<Node<T>*>& buckets){
        int64_t bucket = ptr->key_ & (buckets.size() - 1); // this will give us the bucket
        ptr->next_ = buckets[bucket];   // new node points to old head (null or not) -> this saves us a branch
        buckets[bucket] = ptr;          
    }

    int64_t nearestTwoExp(int64_t capacity){
        int size = 2;
        while (size < capacity){
            size = size << 1;
        }
        return size;
    }

public:
    hashmapSingleThread(int capacity) : capacity_(nearestTwoExp(capacity)), buckets_(capacity_, nullptr){}

    void swap(hashmapSingleThread& other) noexcept{
        using std::swap;
        swap(capacity_, other.capacity_);
        swap(buckets_, other.buckets_);
    }

    hashmapSingleThread& operator=(const hashmapSingleThread& other){
        hashmapSingleThread{other}.swap(*this);
        return *this;
    }

    hashmapSingleThread(const hashmapSingleThread& other) : capacity_(other.capacity_), buckets_(capacity_, nullptr){
        for (int64_t i = 0; i < capacity_; i++){
            Node<T>** tail = &buckets_[i];

            for (auto src = other.buckets_[i]; src; src = src->next_){
                *tail = new Node(src->next_, src->val_, src->key_);
                tail = &((*tail)->next_);
            }
        }
    }


};